# Server
PORT=8080
CORS_ORIGIN=http://localhost:5173

# Auth
JWT_SECRET=replace-this-with-a-secure-secret-of-at-least-32-characters
JWT_EXPIRES_IN=1d

# Firestore
FIRESTORE_USERS_COLLECTION=users
FIRESTORE_CRYPTO_CACHE_COLLECTION=crypto_cache

# Firebase Admin SDK
#
# Option A: explicit service account fields.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Option B: base64 encoded service account JSON.
# If this value is set, the backend uses it before the explicit fields above.
FIREBASE_SERVICE_ACCOUNT_BASE64=base64-encoded-service-account-json

# CoinGecko
COINGECKO_API_KEY=your-coingecko-api-key

# Optional defaults
# NODE_ENV=development
# BCRYPT_SALT_ROUNDS=10
# COINGECKO_API_URL=https://api.coingecko.com/api/v3
# COINGECKO_API_KEY_HEADER=x-cg-demo-api-key
# COINGECKO_TIMEOUT_MS=8000
# COINGECKO_CACHE_TTL_MS=300000
# COINGECKO_STALE_TTL_MS=21600000

# Cloud Run can use Application Default Credentials instead of local Firebase credentials.
